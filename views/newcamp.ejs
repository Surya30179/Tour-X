<% layout('./layouts/boilerplate')%>
    <div class="row">
        <h1 class="text-center"> New Place </h1>
        <div class="col-6 offset-3">
            <form action="/campgrounds" method="POST">
                <div class="mb-3">
                    <label class="form-label" for="title">Enter the Title:</label>
                    <input class="form-control" type="text" name="title">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Enter the Price:</label>
                    <div class="input-group">
                        <span class="input-group-text">INR</span>
                        <input type="text" class="form-control" name="price">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Enter the Description :</label>

                    <textarea class="form-control" id="description" name="description" rows="5"
                        placeholder="Enter description here..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Enter the Location:</label>
                    <input class="form-control" type="text" name="location">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Enter the image link:</label>
                    <input class="form-control" type="text" name="image">
                </div>
                <button class="btn btn-success" type="submit">Submit</button>

            </form>
        </div>
    </div>