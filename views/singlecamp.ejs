    <div class="row mb-5">
        <div class="col-6 offset-3">
            <div class="card">
                <img src="<%= camp.image %>" class="card-img-top" alt="image">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= camp.title %>
                    </h5>
                    <p class="card-text">
                        <%= camp.description %>
                    </p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Entry Price: <%= camp.price %>
                    </li>
                    <li class="list-group-item">Location: <%= camp.location %>
                    </li>

                </ul>
                <div class="card-body">
                    <div class="row">

                        <div class="col-2">
                            <form action="/campgrounds/<%=camp._id%>/edit" method="GET">
                                <button class="btn btn-info" type="submit">UPDATE</button>
                            </form>
                        </div>
                        <div class="col-2">
                            <form action="/campgrounds/<%=camp._id%>?_method=DELETE" method="POST">
                                <button class="btn btn-danger" type="submit">DELETE</button>
                            </form>
                        </div>


                    </div>

                </div>
            </div>
        </div>
    </div>