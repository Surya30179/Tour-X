<% layout('./layouts/boilerplate')%>


    <div class="row mb-5">
        <div class="col-6 offset-3">
            <div class="card">
                <img src="<%= camp.image %>" class="card-img-top" alt="image">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= camp.title %>
                    </h5>
                    <p class="card-text">
                        <%= camp.description %>
                    </p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Entry Price: <%= camp.price %>
                    </li>
                    <li class="list-group-item">Location: <%= camp.location %>
                    </li>

                </ul>
                <div class="card-body">
                    <div class="row">

                        <div class="col-2">
                            <form action="/campgrounds/<%=camp._id%>/edit" method="GET">
                                <button class="btn btn-info" type="submit">UPDATE</button>
                            </form>
                        </div>
                        <div class="col-2">
                            <form action="/campgrounds/<%=camp._id%>?_method=DELETE" method="POST">
                                <button class="btn btn-danger" type="submit">DELETE</button>
                            </form>
                        </div>


                    </div>
                    <h3 class="mt-3">Add a Review</h3>
                    <form action="/campgrounds/<%=camp._id%>/review" method="POST" class="form_to_be_validated"
                        novalidate>

                        <div class="mb-3 mt-3">
                            <label for="rating" class="form-label">Rate the Place</label>
                            <input type="range" class="form-range" min="1" max="5" name="review[rating]">
                        </div>
                        <div class="mb-3">
                            <label for="body" class="form-label">Review</label>
                            <textarea name="review[body]" id="body" cols="30" rows="3" class="form-control" required
                                placeholder="Enter a Review"></textarea>
                            <div class="valid-feedback">
                                Looks good!
                            </div>
                        </div>
                        <button class="btn btn-success submit">Submit</button>
                    </form>

                </div>
            </div>
            <h3 class="ms-1">Reviews</h3>
            <% camp.reviews.forEach(element=> { %>
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-3 offset-1">
                                <p>
                                    <%= element.body %>
                                </p>
                            </div>
                            <div class="col-3 offset-1">
                                <p>
                                    Rating: <%= element.rating %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>