<% layout('./layouts/boilerplate')%>

    <div class="row">
        <h1 class="text-center">Edit the Place</h1>
        <div class="col-6 offset-3">
            <form action="/campgrounds/<%= camp._id%>?_method=PUT" method="POST">
                <div class="mb-3">
                    <label class="form-label" for="title">Edit the Title</label>
                    <input class="form-control" type="text" name="title" value="<%=camp.title %>">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Enter the Price:</label>
                    <div class="input-group">
                        <span class="input-group-text">INR</span>
                        <input type="text" class="form-control" name="price" value="<%= camp.price %>">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Edit the Description :</label>

                    <textarea class="form-control" id="description" name="description"
                        rows="5"><%= camp.description %></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Edit the Location</label>
                    <input class="form-control" type="text" name="location" value="<%= camp.location %>">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Edit the image</label>
                    <input class="form-control" type="text" name="image" value="<%=camp.image %>">
                </div>
                <button class="btn btn-info" type="submit">Update</button>
            </form>
        </div>
    </div>